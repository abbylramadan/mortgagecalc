# Real Estate Market Data API Configuration
# Sign up at https://rapidapi.com for free tier access

# Option 1: Realty Mole API (recommended - free tier available)
# https://rapidapi.com/realtymole/api/realty-mole-property-api
VITE_RAPIDAPI_KEY=your_rapidapi_key_here

# Option 2: Zillow API (alternative)
# https://rapidapi.com/apimaker/api/zillow-com1
# VITE_ZILLOW_API_KEY=your_zillow_key_here

# Set to 'true' to use mock data when API is not configured
VITE_USE_MOCK_DATA=false
